<!--
  Minimal ClickHouse server config for integration tests that launch a local binary
  (opt-in via -DuseClickhouseBinary=true). Mirrors the distribution defaults but scopes
  all paths under /tmp/opensearch-ch-it and binds to loopback only. Verified against
  ClickHouse 24.3 LTS via the M4.7 spike.
-->
<clickhouse>
  <http_port>18123</http_port>
  <tcp_port>19000</tcp_port>
  <listen_host>127.0.0.1</listen_host>
  <path>/tmp/opensearch-ch-it/data/</path>
  <tmp_path>/tmp/opensearch-ch-it/tmp/</tmp_path>
  <user_files_path>/tmp/opensearch-ch-it/user_files/</user_files_path>
  <logger>
    <!-- level=information is required so the `Application:` banner reaches
         stdout; warning-only suppresses it and SpawnProcessTask's `ready`
         watcher will block forever. -->
    <level>information</level>
    <log>/tmp/opensearch-ch-it/clickhouse-server.log</log>
    <errorlog>/tmp/opensearch-ch-it/clickhouse-server.err.log</errorlog>
    <size>100M</size>
    <count>1</count>
    <!-- Mirror log output to stdout so Gradle's SpawnProcessTask can watch
         for the `Application:` ready string. Without this, CH writes only
         to the log file and Gradle hangs waiting for a stdout signal. -->
    <console>1</console>
  </logger>
  <users_config>users.xml</users_config>
  <default_profile>default</default_profile>
  <default_database>default</default_database>
  <mark_cache_size>1073741824</mark_cache_size>
  <mlock_executable>false</mlock_executable>
  <query_log>
    <database>system</database>
    <table>query_log</table>
    <flush_interval_milliseconds>1000</flush_interval_milliseconds>
  </query_log>
</clickhouse>
